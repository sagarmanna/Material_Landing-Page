@model List<MaterialLandingApp.Models.DashboardBoxModel>

<div class="container my-5">
    <div class="row text-center">

        @foreach (var box in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm p-4">

                    <div class="mb-2">
                        <i class="@box.Icon" style="font-size:28px"></i>
                    </div>

                    <h4>@box.Value</h4>

                    <p class="text-muted">@box.Title</p>

                </div>
            </div>
        }

    </div>
</div>