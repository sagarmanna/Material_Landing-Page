@model MaterialLandingApp.Models.LandingPageViewModel

<!DOCTYPE html>
<html>

<head>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />

<link rel="stylesheet" href="~/material-theme/assets/core.css"/>
<link rel="stylesheet" href="~/material-theme/assets/front-page.css"/>
<link rel="stylesheet" href="~/material-theme/assets/front-page-landing.css"/>
<link rel="stylesheet" href="~/material-theme/assets/swiper.css"/>
<link rel="stylesheet" href="~/material-theme/assets/iconify-icons.css"/>
<link rel="stylesheet" href="~/material-theme/assets/node-waves.css"/>
<link rel="stylesheet" href="~/material-theme/assets/demo.css"/>

</head>

<body>

@await Html.PartialAsync("_Header", Model)

@RenderBody()

@await Html.PartialAsync("_Footer")

<script src="~/material-theme/assets/bootstrap.js"></script>
<script src="~/material-theme/assets/front-main.js"></script>
<script src="~/material-theme/assets/front-page-landing.js"></script>

<script>
document.querySelectorAll('a[href^="#"]').forEach(anchor=>{
anchor.addEventListener('click',function(e){
e.preventDefault();
document.querySelector(this.getAttribute('href'))
.scrollIntoView({behavior:'smooth'});
});
});
</script>

</body>
</html>